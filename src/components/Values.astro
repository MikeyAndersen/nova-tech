---
const values = [
  'Jeg tror på at udvikle mennesker, ikke bare systemer',
  'Jeg starter altid med at forstå din situation — ikke med at sælge dig noget',
];
---

<section class="values">
  <div class="container">
    <ul class="values__list">
      {values.map(v => (
        <li class="values__item">
          <span class="values__dot" aria-hidden="true"></span>
          <span>{v}</span>
        </li>
      ))}
    </ul>
  </div>
</section>
