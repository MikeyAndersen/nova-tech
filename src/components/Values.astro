---
const cards = [
  'Jeg tror på at udvikle mennesker, ikke bare systemer.',
  'Jeg starter altid med at forstå din situation — ikke med at sælge dig noget.',
];
---

<section class="values">
  <div class="container">
    <div class="values__grid">
      {cards.map(text => (
        <div class="values__card">
          <span class="values__quote" aria-hidden="true">"</span>
          <p>{text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
