---
import EarDecoration from './EarDecoration.astro';
---

<section class="hero">
  <div class="container hero__grid">

    <div class="hero__content">
      <h1 class="hero__name">
        Mikey Bruun<br />
        <span class="name-light">Andersen</span>
      </h1>
      <p class="hero-tagline">
        Jeg arbejder med mennesker<br />der bygger software —<br />
        som leder, coach eller sparringspartner.
      </p>
      <p class="hero-location">Aarhus · Software konsulent</p>
      <a href="#kontakt" class="hero__cta">Tag fat i mig</a>
    </div>

    <EarDecoration class="hero__deco" />

  </div>
</section>
